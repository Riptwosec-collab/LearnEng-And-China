{
  "name": "linguaquest-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "qa": "npm run prisma:generate && npm run content:validate && npm run typecheck && npm run lint && npm run test && npm run build",
    "format": "prettier --write .",
    "env:check": "tsx scripts/check-env.ts",
    "setup:production": "tsx scripts/setup-production.ts",
    "smoke": "tsx scripts/smoke-test.ts",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "content:expand": "tsx scripts/expand-vocabulary.ts",
    "content:export": "tsx scripts/export-vocabulary-json.ts",
    "content:10k": "EXPANDED_VOCAB_PER_LANGUAGE=5000 tsx scripts/expand-vocabulary.ts",
    "content:validate:600": "tsx scripts/validate-vocabulary-600.ts",
    "content:validate:quality": "tsx scripts/validate-vocabulary-quality.ts",
    "content:validate": "npm run content:validate:600 && npm run content:validate:quality"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-slot": "^1.3.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.41.0",
    "lucide-react": "^1.21.0",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "openai": "^6.44.0",
    "papaparse": "^5.5.4",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^26.0.0",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "prettier": "^3.8.4",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@hono/node-server": "^1.19.13",
    "postcss": "^8.5.16"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
