# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="LinguaQuest AI"
NEXT_PUBLIC_ENABLE_MOCK_AI=false
NEXT_PUBLIC_ENABLE_MOCK_SPEECH=false

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# PostgreSQL / Prisma
DATABASE_URL="postgresql://postgres:password@localhost:5432/linguaquest_ai?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:5432/linguaquest_ai?schema=public"

# AI Provider: openai | openrouter | gemini
AI_PROVIDER="openai"

# OpenAI
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"
OPENAI_TEXT_MODEL="gpt-4.1-mini"
OPENAI_SPEECH_MODEL="gpt-4o-mini-tts"
OPENAI_TRANSCRIBE_MODEL="gpt-4o-mini-transcribe"

# OpenRouter
OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY"
OPENROUTER_TEXT_MODEL="google/gemini-flash-1.5"

# Gemini
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
GEMINI_TEXT_MODEL="gemini-1.5-flash"

# Content expansion
EXPANDED_VOCAB_PER_LANGUAGE=500

# Admin access (comma-separated emails)
ADMIN_EMAILS="admin@example.com"

# Optional deployment metadata
VERCEL_PROJECT_ID=""
VERCEL_ORG_ID=""
